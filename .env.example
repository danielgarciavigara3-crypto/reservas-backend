# Copia este archivo como ".env" y rellena tus datos reales.
# Mientras RESEND_API_KEY esté vacío o con el valor de ejemplo,
# el servidor funciona en "modo desarrollo": no envía emails de verdad,
# solo imprime el código en la consola para que puedas probar.

PORT=3000

# Tu clave de API de Resend (la consigues gratis en resend.com)
RESEND_API_KEY=tu_clave_aqui

# El email desde el que se enviarán los códigos.
# Al principio, mientras no verifiques tu propio dominio en Resend,
# usa exactamente este valor de pruebas que ellos ofrecen gratis:
FROM_EMAIL=onboarding@resend.dev
